<?xml version="1.0" encoding="utf-8"?>
<!-- 竖屏布局：垂直排列 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/dialog_about_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- 应用图标 -->
        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/vplus"
            android:contentDescription="@string/app_label"
            android:scaleType="fitCenter"
            android:layout_marginBottom="12dp" />

        <!-- 应用名称 -->
        <TextView
            android:id="@+id/text_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MoonLink"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_dialog_title_color"
            android:layout_marginBottom="4dp" />

        <!-- 版本信息 -->
        <TextView
            android:id="@+id/text_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 0.0.0 (Build 0)"
            android:textSize="12sp"
            android:textColor="@color/app_dialog_subtitle_color"
            android:layout_marginBottom="16dp" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/app_dialog_accent_color"
            android:layout_marginBottom="16dp" />

        <!-- 描述信息 -->
        <TextView
            android:id="@+id/text_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_dialog_description"
            android:textSize="14sp"
            android:textColor="@color/app_dialog_title_color"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="8dp" />

        <!-- 项目信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_dialog_project_info"
            android:textSize="12sp"
            android:textColor="@color/app_dialog_subtitle_color"
            android:layout_marginBottom="6dp" />

        <!-- 感谢信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/about_dialog_thanks"
            android:textSize="12sp"
            android:textColor="@color/app_dialog_subtitle_color"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
